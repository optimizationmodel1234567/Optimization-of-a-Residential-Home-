m.casa_from_batt = pe.Var(m.time, domain=pe.NonNegativeReals, bounds=(0, None))
m.casa_from_ev = pe.Var(m.vehicles, m.time, domain=pe.NonNegativeReals, bounds=(0, None))

# EV charging variables
m.charge_solar = pe.Var(m.vehicles, m.time, domain=pe.NonNegativeReals)
m.charge_grid = pe.Var(m.vehicles, m.time, domain=pe.NonNegativeReals)
m.energy = pe.Var(m.vehicles, m.time, domain=pe.NonNegativeReals)
m.ev_charging = pe.Var(m.vehicles, m.time, within=pe.Binary)
m.ev_discharging = pe.Var(m.vehicles, m.time, within=pe.Binary)

# V2X variables
m.discharge_grid = pe.Var(m.vehicles, m.time, domain=pe.NonNegativeReals, bounds=(0, 2.5))
m.v2x_active = pe.Var(m.vehicles, m.time, within=pe.Binary)

# Charger assignment
m.vehicle_charger_assignment = pe.Var(m.vehicles, m.chargers, m.time, domain=pe.Binary)

# Bateria fixa
m.bateria_capacidade_max = pe.Param(within=pe.NonNegativeReals, initialize=bateria_capacidade_max_value)
m.bateria_potencia_max = pe.Param(within=pe.NonNegativeReals, initialize=bateria_potencia_max_value)
m.bateria_energia = pe.Var(m.time, domain=pe.NonNegativeReals)
m.bateria_carga = pe.Var(m.time, domain=pe.NonNegativeReals, bounds=(0, m.bateria_potencia_max))
m.bateria_descarga = pe.Var(m.time, domain=pe.NonNegativeReals, bounds=(0, m.bateria_potencia_max))
m.bateria_descarga_grid = pe.Var(m.time, domain=pe.NonNegativeReals, bounds=(0, m.bateria_potencia_max))

# EV charging from HOME battery
m.ev_charge_from_home_batt = pe.Var(m.vehicles, m.time, domain=pe.NonNegativeReals, bounds=(0, m.bateria_potencia_max))

# PV grid
m.pv_to_grid = pe.Var(m.time, domain=pe.NonNegativeReals)

#Loads

# Deferrable
m.DL1 = pe.Set(initialize=DL1)
m.DL2 = pe.Set(initialize=DL2)
m.DL1_active = pe.Var(m.DL1, m.time, within=pe.Binary)
m.DL1_start = pe.Var(m.DL1, m.time, within=pe.Binary)
m.DL2_active = pe.Var(m.DL2, m.time, within=pe.Binary)
m.DL = pe.Set(initialize=DL_all)

m.total_energy = pe.Param(m.DL, initialize=total_energy)
m.duration     = pe.Param(m.DL, initialize=duration)
missing = [l for l in DL1 + DL2 if l not in duration]



# Dimmable
m.DIM = pe.Set(initialize=DIM)
m.DIM_on = pe.Var(m.DIM, m.time, within=pe.Binary)
m.DIM_level = pe.Var(m.DIM, m.time, bounds=(0,1))

#Fixed
m.LOADS_ALL = pe.Set(initialize=loads_in_sheet2)

m.base_load = pe.Param(
    m.time,
    m.LOADS_ALL,
    initialize=lambda m, t, l: base_consumption.get((l, t), 0.0),
    within=pe.NonNegativeReals
)
EPS = 1e-6  # safety but not critical if dim_reduction never small

# FUNÇÃO OBJETIVO
obj_expr = (
    sum(m.cost[t] * sum(m.charge_grid[v, t] for v in m.vehicles) for t in m.time)
    +sum(m.cost[t] * m.casa_from_grid[t] for t in m.time)
    +sum(penalização_bateria_arm * m.bateria_descarga[t] for t in m.time)
    -sum(m.sell_price[t] * sum(m.discharge_grid[v, t] for v in m.vehicles) for t in m.time)
    -sum(m.sell_price[t] * m.bateria_descarga_grid[t] for t in m.time)
    -sum(m.sell_price[t] * m.pv_to_grid[t] for t in m.time)
)

obj_expr += sum(
   m.pen_vei_bat[v] * m.casa_from_ev[v, t]
    for v in m.vehicles
    for t in m.time
)

obj_expr += sum(
   m.pen_vei_bat[v] * m.discharge_grid[v, t]
    for v in m.vehicles
    for t in m.time
)

#conforto deferrable
obj_expr += sum(comfort.get((l, t), 0.0)* m.DL1_active[l, t]for l in m.DL1 for t in m.time)

obj_expr += sum(comfort.get((l, t), 0.0) * m.DL2_active[l, t]for l in m.DL2 for t in m.time)

# conforto dimm
obj_expr += sum(
   m.base_load[t,id_to_col_sheet2[l]]* comfort.get((l,t),0) *(m.DIM_level[l,t] / dim_reduction.get((l,t),0)
   + EPS)
   for l in m.DIM for t in m.time
)



m.obj = pe.Objective(expr=obj_expr, sense=pe.minimize)

# RESTRIÇÕES
# Restrição 1 (a), (b): Equilibrio de energia da casa
def define_house_demand(m, t):

    fixed = sum(m.base_load[t, l] for l in m.LOADS_FIXED)

    dl1 = sum(
        (m.total_energy[l] / m.duration[l]) * m.DL1_active[l, t]
        for l in m.DL1
    )

    dl2 = sum(
        (m.total_energy[l] / m.duration[l]) * m.DL2_active[l, t]
        for l in m.DL2
    )

    dim = sum(
    m.base_load[t, id_to_col_sheet2[l]] * (1 - m.DIM_level[l,t])
    for l in m.DIM
    )

    return m.house_demand[t] == fixed + dl1 + dl2 + dim
m.house_demand_def = pe.Constraint(m.time, rule=define_house_demand)

def house_supply_balance(m, t):
    supply = sum(m.casa_from_ev[v, t] for v in m.vehicles) + m.casa_from_grid[t] + m.casa_from_pv[t] + m.casa_from_batt[t]
    return supply == m.house_demand[t]
m.casa_balance = pe.Constraint(m.time, rule=house_supply_balance)




# Restrição 2 a)/b): Trocas de energia da bateria fixa
def bateria_acumulada(m, t):
    if t == m.time.first():
        return m.bateria_energia[t] == (
            m.bateria_carga[t] -
            m.casa_from_batt[t] -
           sum(m.ev_charge_from_home_batt[v, t] for v in m.vehicles) -
            m.bateria_descarga_grid[t]
        )
    else:
        anterior = list(m.time.ordered_data())[list(m.time.ordered_data()).index(t)-1]
        return m.bateria_energia[t] == (
            m.bateria_energia[anterior] +
            m.bateria_carga[t] -
            m.casa_from_batt[t] -
            sum(m.ev_charge_from_home_batt[v, t] for v in m.vehicles) -
            m.bateria_descarga_grid[t]
        )
m.bateria_acumulada = Constraint(m.time, rule=bateria_acumulada)

def bateria_descarga_total(m, t):
    return m.bateria_descarga[t] == (
        m.casa_from_batt[t] +
          sum(m.ev_charge_from_home_batt[v, t] for v in m.vehicles)  +
        m.bateria_descarga_grid[t]
    )
m.bateria_descarga_total = Constraint(m.time, rule=bateria_descarga_total)

# Restrição 3: Carga máxima da bateria fixa
def bateria_capacidade_maxima(m, t):
    return m.bateria_energia[t] <= m.bateria_capacidade_max
m.bateria_capacidade_maxima = Constraint(m.time, rule=bateria_capacidade_maxima)

def battery_power_limit(m, t):
    return m.bateria_carga[t] <= m.bateria_potencia_max

m.battery_power_limit = Constraint(m.time, rule=battery_power_limit)

# Restrição 4 a)/b): Atribuição de carregadores
def charger_assignment(m, v, t):
    return sum(m.vehicle_charger_assignment[v, c, t] for c in m.chargers) <= 1
m.charger_assignment_constraint = Constraint(m.vehicles, m.time, rule=charger_assignment)

def max_vehicles_per_charger(m, c, t):
    return sum(m.vehicle_charger_assignment[v, c, t] for v in m.vehicles) <= 1
m.max_vehicles_per_charger = Constraint(m.chargers, m.time, rule=max_vehicles_per_charger)

# Restrição 5: Carregar ou descarregar apenas quando disponível e com carregador
def ev_charge_only_when_home(m, v, t):
    M = 1000
    charger_assigned = sum(m.vehicle_charger_assignment[v, c, t] for c in m.chargers)

    return (m.charge_grid[v, t] +
            m.charge_solar[v, t] +
            m.ev_charge_from_home_batt[v, t] +
            m.discharge_grid[v, t] +
            m.casa_from_ev[v, t]) <= M * m.available[v, t] * charger_assigned

m.ev_charge_only_when_home = Constraint(m.vehicles, m.time, rule=ev_charge_only_when_home)


# Restrição 6: Limitar energia do PV
def limite_solar_corrigido(m, t):
    return (
        m.casa_from_pv[t]
        + m.bateria_carga[t]
        + sum(m.charge_solar[v, t] for v in m.vehicles)
        + m.pv_to_grid[t]
        == m.solar[t]
    )
m.restricao_solar_corrigida = Constraint(m.time, rule=limite_solar_corrigido)
# Restrição 7: a) Carga no EV /  b) c) d) carrega ou descarrega
def energy_accumulation_rule(m, v, t):
    if t == m.time.first():
        return m.energy[v, t] == (
            m.initial_energy[v, t] +
            m.charge_grid[v, t] + m.charge_solar[v, t] + m.ev_charge_from_home_batt[v, t] -
            m.gasto[v, t] -
            m.discharge_grid[v, t] -
            m.casa_from_ev[v, t]

        )
    else:
        prev = list(m.time.ordered_data())[list(m.time.ordered_data()).index(t) - 1]
        return m.energy[v, t] == (
            m.energy[v, prev] +
            m.charge_grid[v, t] + m.charge_solar[v, t] + m.ev_charge_from_home_batt[v, t] -
            m.gasto[v, t] -
            m.discharge_grid[v, t]-
            m.casa_from_ev[v, t]
        )
m.energy_accumulation = Constraint(m.vehicles, m.time, rule=energy_accumulation_rule)

def ev_mode_exclusivity(m, v, t):
    return m.ev_charging[v, t] + m.ev_discharging[v, t] <= 1
m.ev_mode_exclusivity = Constraint(m.vehicles, m.time, rule=ev_mode_exclusivity)

def ev_charging_link(m, v, t):
    M = m.charge_limit_param[v]
    return (
        m.charge_grid[v, t]
        + m.charge_solar[v, t]
        + m.ev_charge_from_home_batt[v, t]
        <= M * m.ev_charging[v, t]
    )
m.ev_charging_link = Constraint(m.vehicles, m.time, rule=ev_charging_link)

def ev_discharging_link(m, v, t):
    M = m.ev_discharge_limit_param[v]
    return (
        m.discharge_grid[v, t]
        + m.casa_from_ev[v, t]
        <= M * m.ev_discharging[v, t]
    )
m.ev_discharging_link = Constraint(m.vehicles, m.time, rule=ev_discharging_link)

# Restrição 8: Energia mínima necessária
def demand_energy_rule(m, v, t):
    return m.energy[v, t] >= m.min_energy[v, t]
m.demand_energy_constraint = Constraint(m.vehicles, m.time, rule=demand_energy_rule)

# Restrição 9: Limite da capacidade da bateria
def limite_capacidade_bateria(m, v, t):
    return m.energy[v, t] <= m.full_tank[v]
m.limite_capacidade_bateria = Constraint(m.vehicles, m.time, rule=limite_capacidade_bateria)

# Restrição 10 a)/b): Venda de energia da bateria fixa
def bateria_descarga_grid_limite(m, t):
    return m.bateria_descarga_grid[t] <= m.bateria_energia[t]
m.bateria_descarga_grid_constraint_energy = Constraint(m.time, rule=bateria_descarga_grid_limite)

def bateria_descarga_grid_potencia_limite(m, t):
    return m.bateria_descarga_grid[t] <= m.bateria_potencia_max
m.bateria_descarga_grid_constraint_power = Constraint(m.time, rule=bateria_descarga_grid_potencia_limite)

# Restrição 11 a)/b)/c): V2X activation
def min_soc_v2x_constraint_strong(m, v, t):
    total_discharge = m.discharge_grid[v, t] + m.casa_from_ev[v, t]
    M = 1000
    # Big-M method: if discharging, SOC must be above minimum
    return m.energy[v, t] >= m.min_soc_v2x[v] * m.vehicle_capacity[v] - M * (1 - m.v2x_active[v, t])
m.min_soc_v2x_constraint_strong = Constraint(m.vehicles, m.time, rule=min_soc_v2x_constraint_strong)

def force_v2x_active(m, v, t):
    total_discharge = m.discharge_grid[v, t] + m.casa_from_ev[v, t]
    M = 1000
    return total_discharge <= M * m.v2x_active[v, t]
m.force_v2x_active = Constraint(m.vehicles, m.time, rule=force_v2x_active)

# If min_soc_v2x == 1, no V2X
def no_v2x_when_min_soc_is_1(m, v, t):
    if m.min_soc_v2x[v] == 1.0:
        return m.discharge_grid[v, t] + m.casa_from_ev[v, t] == 0
    return Constraint.Skip
m.no_v2x_when_min_soc_is_1 = Constraint(m.vehicles, m.time, rule=no_v2x_when_min_soc_is_1)



# Restrição 13: Limite carregamento do EV
def constant_charging_limit(m, v, t):
    total_charge = (
        m.charge_grid[v, t] +
        m.charge_solar[v, t] +
        m.ev_charge_from_home_batt[v, t]
    )
    return total_charge <= m.charge_limit_param[v]
m.constant_charging_limit = Constraint(m.vehicles, m.time, rule=constant_charging_limit)

# Restrição 14: Limite V2X
def ev_discharge_limit_rule(m, v, t):
    return m.discharge_grid[v, t] <= m.ev_discharge_limit_param[v]
m.ev_discharge_limit_constraint = Constraint(m.vehicles, m.time, rule=ev_discharge_limit_rule)

# Restrição 15: Deferrable loads

# Type 2 a)/b)/c)/d)/e)/f)
def duration_rule(m, l):
    return sum(m.DL1_active[l, t] for t in m.time) == m.duration[l]
m.DL1_duration = pe.Constraint(m.DL1, rule=duration_rule)

def energy_rule_DL1(m, l):
    power = m.total_energy[l] / m.duration[l]
    return sum(power * m.DL1_active[l, t] for t in m.time) == m.total_energy[l]

m.DL1_energy = pe.Constraint(m.DL1, rule=energy_rule_DL1)


def DL1_availability(m, l, t):
    return m.DL1_active[l, t] <= availability.get((l, t), 1)
m.DL1_availability = pe.Constraint(m.DL1, m.time, rule=DL1_availability)


def DL1_start_link(m, l, t):
    times = list(m.time.ordered_data())
    i = times.index(t)

    if i == 0:
        return m.DL1_start[l, t] >= m.DL1_active[l, t]
    else:
        return m.DL1_start[l, t] >= m.DL1_active[l, t] - m.DL1_active[l, times[i-1]]

m.DL1_start_link = pe.Constraint(m.DL1, m.time, rule=DL1_start_link)

def DL1_single_start(m, l):
    return sum(m.DL1_start[l, t] for t in m.time) == 1

m.DL1_single_start = pe.Constraint(m.DL1, rule=DL1_single_start)

def DL1_continuity(m, l, t):
    dur = int(m.duration[l])
    times = list(m.time.ordered_data())
    i = times.index(t)

    if i + dur > len(times):
        return pe.Constraint.Skip

    return sum(
        m.DL1_active[l, times[i+k]]
        for k in range(dur)
    ) >= dur * m.DL1_start[l, t]

m.DL1_continuity = pe.Constraint(m.DL1, m.time, rule=DL1_continuity)


# Type 2 a)/b)/c)

def energy_rule_DL2(m, l):
    power = m.total_energy[l] / m.duration[l]
    return sum(power * m.DL2_active[l, t] for t in m.time) == m.total_energy[l]

m.DL2_energy = pe.Constraint(m.DL2, rule=energy_rule_DL2)

def duration_rule2(m, l):
    return sum(m.DL2_active[l, t] for t in m.time) == m.duration[l]
m.DL2_duration = pe.Constraint(m.DL2, rule=duration_rule2)

def DL2_availability(m, l, t):
    return m.DL2_active[l, t] <= availability.get((l, t), 1)
m.DL2_availability = pe.Constraint(m.DL2, m.time, rule=DL2_availability)

